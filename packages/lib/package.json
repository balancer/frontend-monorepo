{
  "name": "@repo/lib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "graphql:gen": "DOTENV_CONFIG_PATH=./.env.local graphql-codegen -r dotenv/config -c ./shared/services/api/codegen.ts",
    "lint": "eslint . --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --max-warnings 0 --cache",
    "prettier": "prettier '**/*.*(md|json|yaml|ts|js|tsx)' --check --cache --log-level=warn",
    "prettier:fix": "prettier '**/*.*(md|json|yaml|ts|js|tsx)' --write --cache --log-level=warn",
    "stylelint": "stylelint '**/*.css'",
    "stylelint:fix": "stylelint '**/*.css' --fix",
    "test": "pnpm test:unit & pnpm run test:integration",
    "test:integration": "vitest run -c ./vitest.config.integration.ts",
    "test:integration:watch": "vitest -c ./vitest.config.integration.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest --coverage",
    "test:unit:silent:coverage": "SILENT_TESTS=true vitest --coverage",
    "test:save-api-mocks": "vitest run -c ./vitest.config.scripts.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit --incremental"
  },
