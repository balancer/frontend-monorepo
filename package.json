{
  "name": "@balancer/frontend-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "dev": "pnpm run dev:bal",
    "dev:bal": "turbo dev --filter frontend-v3",
    "dev:bal:fork": "NEXT_PUBLIC_E2E_DEV=1 pnpm dev:bal",
    "dev:beets": "turbo dev --filter beets-frontend-v3",
    "dev:beets:fork": "NEXT_PUBLIC_E2E_DEV=1 pnpm dev:beets",
    "graphql:gen": "turbo graphql:gen",
    "lint:all": "turbo run lint format --continue",
    "lint:all:fix": "turbo run lint:fix format:fix --continue --force",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "prettier": "turbo prettier",
    "prettier:fix": "turbo prettier:fix",
    "stylelint": "turbo stylelint",
    "stylelint:fix": "turbo stylelint:fix",
    "test:e2e:build:bal": "turbo test:e2e:build:bal --ui=stream --log-order=stream --",
    "test:e2e:build:ui:bal": "turbo test:e2e:build:ui:bal --ui=stream --log-order=stream --",
    "test:e2e:build:beets": "turbo test:e2e:build:beets --ui=stream --log-order=stream --",
    "test:e2e:build:ui:beets": "turbo test:e2e:build:ui:beets --ui=stream --log-order=stream --",
    "test:e2e:dev:bal": "NEXT_PUBLIC_E2E_DEV=1 turbo test:e2e:dev:bal --ui=stream --log-order=stream --",
    "test:e2e:dev:ui:bal": "NEXT_PUBLIC_E2E_DEV=1 turbo test:e2e:dev:ui:bal --ui=stream --log-order=stream --",
    "test:e2e:dev:beets": "NEXT_PUBLIC_E2E_DEV=1 turbo test:e2e:dev:beets --ui=stream --log-order=stream --",
    "test:e2e:dev:ui:beets": "NEXT_PUBLIC_E2E_DEV=1 turbo test:e2e:dev:ui:beets --ui=stream --log-order=stream --",
    "test:integration": "turbo test:integration --ui=stream --log-order=stream --",
    "test:integration:watch": "turbo test:integration:watch --ui=stream --log-order=stream --",
    "test:unit": "turbo test:unit --ui=stream --log-order=stream --",
    "test:unit:watch": "turbo test:unit:watch --ui=stream --log-order=stream --",
    "test:save-api-mocks": "turbo test:save-api-mocks --ui=stream --log-order=stream --",
    "typecheck": "turbo typecheck",
    "prepare": "husky",
    "playwright:install": "pnpm --filter=e2e-tests playwright:install",
    "playwright:install:chromium": "pnpm --filter=e2e-tests playwright:install:chromium"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.6",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "sharp": "0.34.5",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-prettier": "5.0.3",
    "turbo": "2.9.7",
    "typescript": "5.9.3",
    "vitest": "3.2.6",
    "vitest-mock-extended": "3.1.1"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "engines": {
    "node": "24.x",
    "pnpm": ">=8"
  }
}
