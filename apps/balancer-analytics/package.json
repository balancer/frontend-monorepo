{
  "name": "balancer-analytics",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "next start -p 3002",
    "build": "pnpm --filter @repo/lib graphql:gen && pnpm graphql:gen && next build",
    "dev": "concurrently \"pnpm --filter @repo/lib graphql:gen --watch\" \"pnpm graphql:gen --watch\" \"next dev -p 3002\"",
    "dev:no-gen": "next dev -p 3002",
    "graphql:gen": "graphql-codegen -c ./codegen.ts",
    "lint": "eslint . --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --max-warnings 0 --cache",
    "prettier": "prettier '**/*.*(md|json|yaml|ts|js|tsx)' --check --cache --log-level warn",
    "prettier:fix": "prettier '**/*.*(md|json|yaml|ts|js|tsx)' --write --cache --log-level=warn",
    "typecheck": "tsc --project tsconfig.json --noEmit --incremental",
    "gen:theme-typings": "chakra-cli tokens ./lib/services/chakra/themes/analytics/analytics.theme.ts",
    "postinstall": "pnpm run gen:theme-typings"
  },
  "dependencies": {
    "@apollo/client": "catalog:",
    "@chakra-ui/icons": "2.2.4",
    "@chakra-ui/react": "2.10.10",
    "@chakra-ui/theme-tools": "2.2.6",
    "@neondatabase/serverless": "0.10.4",
    "@repo/lib": "workspace:*",
    "@sentry/nextjs": "10.56.0",
    "@tanstack/react-query": "5.101.1",
    "echarts": "6.1.0",
    "echarts-for-react": "3.0.6",
    "motion": "12.40.0",
    "next": "16.2.9",
    "nextjs-toploader": "3.9.17",
    "nuqs": "2.8.9",
    "p-limit": "6.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-feather": "^2.0.10",
    "viem": "2.51.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@chakra-ui/cli": "2.5.8",
    "@chakra-ui/styled-system": "2.12.0",
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.1",
    "eslint": "9.39.4",
    "graphql": "16.14.2"
  },
  "engines": {
    "node": "24.x"
  },
  "engineStrict": true
}
